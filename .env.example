# Copy to .env and fill in. These override config.yaml.
#
# You usually do NOT need this file. Connecting an AI from the menu bar
# (AI engine → pick a provider) stores your key in the macOS Keychain instead,
# which is safer and survives reinstalls. This file is for headless setups and
# for running from source.
#
# Running fully local with Ollama needs no key at all.

# --- API keys ---

# Claude
ANTHROPIC_API_KEY=

# Any OpenAI-compatible endpoint. Groq and Gemini ride this one too: point
# llm.openai.base_url at the provider and set llm.openai.api_key_env to the
# variable you want read (see README → Configuration).
OPENAI_API_KEY=

# --- config.yaml overrides ---

# Which transport handles cleanup: ollama | claude | openai | none
# VOOOXLY_LLM_BACKEND=claude

# Whisper model. whisper.cpp uses ggml .bin files, looked up in
# ~/.voooxly/models/. Pass a bare name here, or an absolute path via
# VOOOXLY_STT_MODEL_FILE.
# VOOOXLY_STT_MODEL=ggml-large-v3-turbo

# Force the output language. Unset (the default) keeps whatever you spoke.
# VOOOXLY_APP_LANGUAGE=es
